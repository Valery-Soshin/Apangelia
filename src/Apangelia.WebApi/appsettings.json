{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Integrations": {
    "Telegram": {
      "ApiBaseUrl": "https://api.telegram.org/"
    }
  },
  "BackgroundWorkers": {
    "TelegramWebhookRegistration": {
      "Enabled": false,
      "PublicUrl": "",
      "AllowedUpdates": [
        "message"
      ],
      "DropPendingUpdates": false
    },
    "NotificationDelivery": {
      "BatchSize": 10,
      "PollingInterval": "00:00:10",
      "MaxAttempts": 5,
      "InitialRetryDelay": "00:01:00"
    }
  },
  "AllowedHosts": "*"
}
